rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global catch-all default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive definitions & Authentication helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprint: User Info Schema
    function isValidUser(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.email is string && data.email.size() <= 150
        && data.points is int
        && data.totalSavedKg is number
        && data.streakDays is int
        && data.smartMeterConnected is bool
        && data.transportTrackerConnected is bool;
    }

    // Validation Blueprint: Emissions Log entry schema
    function isValidEmissionsLog(data) {
      return data.logId is string && data.logId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.category is string && data.category.size() <= 50
        && data.kgSaved is number
        && data.activityName is string && data.activityName.size() <= 200
        && data.timestamp is string && data.timestamp.size() <= 100
        && data.source is string && data.source.size() <= 50;
    }

    // Validation Blueprint: Completed Challenge
    function isValidCompletedChallenge(data) {
      return data.challengeId is string && data.challengeId.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.completedAt is string && data.completedAt.size() <= 100
        && data.pointsEarned is int;
    }

    // Validation Blueprint: Leaderboard Entry
    function isValidLeaderboardEntry(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.name is string && data.name.size() <= 100
        && data.points is int
        && data.totalSavedKg is number
        && data.avatar is string && data.avatar.size() <= 50;
    }

    // Rule: Users profile
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasAny(['name', 'points', 'totalSavedKg', 'streakDays', 'lastActiveDate', 'smartMeterConnected', 'transportTrackerConnected', 'avatar'])
      );
      allow delete: if false;
    }

    // Rule: Emissions Logs
    match /users/{userId}/emissions_logs/{logId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidEmissionsLog(incoming()) && incoming().userId == userId;
      allow update: if false; // Carbon credits/log entries are immutable audit trails
      allow delete: if isOwner(userId);
    }

    // Rule: Completed Challenges
    match /users/{userId}/completed_challenges/{challengeId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidCompletedChallenge(incoming()) && incoming().userId == userId;
      allow update: if false; // Badges completed are immutable achievements
      allow delete: if false;
    }

    // Rule: Global Leaderboard Entries
    match /leaderboard/{userId} {
      allow list, get: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidLeaderboardEntry(incoming());
      allow delete: if false;
    }
  }
}
