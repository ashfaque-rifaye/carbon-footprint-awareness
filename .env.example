# GEMINI_API_KEY: Required for Gemini AI calls (insights + chat coach).
# Read server-side only; never exposed to the browser. Without it, the app
# falls back to its deterministic rule-based engine.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GEMINI_MODEL / GEMINI_FALLBACK_MODEL (optional): primary and fallback models.
# Defaults: gemini-3.5-flash, then gemini-2.5-flash.
# GEMINI_MODEL="gemini-3.5-flash"
# GEMINI_FALLBACK_MODEL="gemini-2.5-flash"

# DB_PATH (optional): location of the local SQLite database file.
# Defaults to ./data/carbonsync.db locally; set to /tmp/carbonsync.db on Cloud Run.
# DB_PATH="data/carbonsync.db"

# APP_URL (optional): the public URL where this app is hosted.
APP_URL="MY_APP_URL"
