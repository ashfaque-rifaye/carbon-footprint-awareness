{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with gamified scores and integration preferences",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "Unique identifier of the user"
        },
        "name": {
          "type": "string",
          "description": "Display name of the user"
        },
        "email": {
          "type": "string",
          "description": "Email address of the user"
        },
        "points": {
          "type": "integer",
          "description": "Gamified score points earned by the user"
        },
        "totalSavedKg": {
          "type": "number",
          "description": "Total carbon saved in kg of CO2 equivalent"
        },
        "streakDays": {
          "type": "integer",
          "description": "Current active daily streak"
        },
        "lastActiveDate": {
          "type": "string",
          "description": "Last logged saving date (YYYY-MM-DD)"
        },
        "avatar": {
          "type": "string",
          "description": "Selected avatar icon name"
        },
        "smartMeterConnected": {
          "type": "boolean",
          "description": "Whether virtual smart utility meter integration is enabled"
        },
        "transportTrackerConnected": {
          "type": "boolean",
          "description": "Whether virtual transport tracker is enabled"
        },
        "createdAt": {
          "type": "string",
          "description": "Timestamp of profile creation"
        }
      },
      "required": ["userId", "name", "email", "points", "totalSavedKg", "streakDays", "smartMeterConnected", "transportTrackerConnected"]
    },
    "EmissionsLog": {
      "title": "Emissions Log",
      "description": "An action log documenting a carbon saving activity",
      "type": "object",
      "properties": {
        "logId": {
          "type": "string",
          "description": "Unique log identifier"
        },
        "userId": {
          "type": "string",
          "description": "The creator of the log"
        },
        "category": {
          "type": "string",
          "description": "Category: transport, energy, diet, or waste"
        },
        "kgSaved": {
          "type": "number",
          "description": "Kg of CO2 saved"
        },
        "activityName": {
          "type": "string",
          "description": "Description of the positive carbon action"
        },
        "timestamp": {
          "type": "string",
          "description": "Timestamp of the activity"
        },
        "source": {
          "type": "string",
          "description": "Source of log: manual, smart_meter, transport_tracker"
        }
      },
      "required": ["logId", "userId", "category", "kgSaved", "activityName", "timestamp", "source"]
    },
    "CompletedChallenge": {
      "title": "Completed Challenge",
      "description": "Records the gamified challenges completed by the user",
      "type": "object",
      "properties": {
        "challengeId": {
          "type": "string",
          "description": "The static ID of the challenge completed"
        },
        "userId": {
          "type": "string",
          "description": "The user who completed the challenge"
        },
        "completedAt": {
          "type": "string",
          "description": "Completion timestamp"
        },
        "pointsEarned": {
          "type": "integer",
          "description": "Points received"
        }
      },
      "required": ["challengeId", "userId", "completedAt", "pointsEarned"]
    },
    "LeaderboardEntry": {
      "title": "Leaderboard Entry",
      "description": "Denormalized flat ranking for super fast retrieval and social features",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The user id"
        },
        "name": {
          "type": "string",
          "description": "The user name"
        },
        "points": {
          "type": "integer",
          "description": "Total gamified points"
        },
        "totalSavedKg": {
          "type": "number",
          "description": "Total footprint reduction"
        },
        "avatar": {
          "type": "string",
          "description": "User avatar"
        }
      },
      "required": ["userId", "name", "points", "totalSavedKg", "avatar"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Reads and writes individual user information"
    },
    "/users/{userId}/emissions_logs/{logId}": {
      "schema": "EmissionsLog",
      "description": "Individual impact logging entries"
    },
    "/users/{userId}/completed_challenges/{challengeId}": {
      "schema": "CompletedChallenge",
      "description": "List of completed badges and challenges per user"
    },
    "/leaderboard/{userId}": {
      "schema": "LeaderboardEntry",
      "description": "Global user leaderboards for community rankings"
    }
  }
}
