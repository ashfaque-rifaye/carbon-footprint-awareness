{
  "name": "carbonsync",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered personal carbon coach — track your footprint and get impact-ranked next actions from a Gemini coach. PromptWars Challenge 3.",
  "license": "MIT",
  "author": "Ashfaque Rifaye",
  "type": "module",
  "keywords": [
    "carbon-footprint",
    "sustainability",
    "gemini",
    "ai-coach",
    "react",
    "typescript",
    "express"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ashfaque-rifaye/carbon-footprint-awareness.git"
  },
  "homepage": "https://github.com/ashfaque-rifaye/carbon-footprint-awareness#readme",
  "bugs": {
    "url": "https://github.com/ashfaque-rifaye/carbon-footprint-awareness/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "eslint . && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "eslint": "^10.5.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^6.2.3",
    "vitest": "^4.1.9"
  }
}
